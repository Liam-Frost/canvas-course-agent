<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.canvas-course-agent.remind</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <!-- Edit the cd path + env path for your install -->
    <string>cd "$HOME/canvas-course-agent" && canvas-agent --env-path .env remind run --lookahead-min 2 --send-discord</string>
  </array>

  <key>StartInterval</key>
  <integer>60</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>$HOME/Library/Logs/canvas-course-agent-remind.log</string>
  <key>StandardErrorPath</key>
  <string>$HOME/Library/Logs/canvas-course-agent-remind.err.log</string>
</dict>
</plist>
