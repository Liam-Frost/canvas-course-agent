# Canvas
CANVAS_BASE_URL=https://canvas.ubc.ca
CANVAS_ACCESS_TOKEN=replace-me

# Storage
DB_PATH=./data/agent.db

# Display timezone (IANA name). Examples:
# - America/Vancouver
# - Asia/Shanghai
TIMEZONE=UTC

# Reminders / output
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# TELEGRAM_BOT_TOKEN=123456:ABC...

# AI adapter (phase 1)
# provider: auto | codex-oauth | openai-api
AI_PROVIDER=auto
# AI_MODEL=gpt-5.3-codex
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
